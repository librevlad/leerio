# Trello integration (optional, admin-only)
TRELLO_API_KEY=
TRELLO_TOKEN=

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=

# JWT secret (required — random 64-char string)
JWT_SECRET=

# Dev mode: disables secure cookie flag (local dev only)
# LEERIO_DEV=1

# Allowed emails (comma-separated; empty = open registration)
# ALLOWED_EMAILS=librevlad@gmail.com

# CORS allowed origins (comma-separated; defaults to localhost dev ports)
# CORS_ORIGINS=http://localhost:5173,http://localhost:80
# Production:
# CORS_ORIGINS=https://app.leerio.app

# Paths (defaults work for local dev; override for Docker)
# LEERIO_DATA=./data
# LEERIO_BOOKS=./books
