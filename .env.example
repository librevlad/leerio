# Trello integration (optional)
TRELLO_API_KEY=
TRELLO_TOKEN=

# CORS allowed origins (comma-separated; defaults to localhost dev ports)
# CORS_ORIGINS=http://localhost:5173,http://localhost:80
# Production:
# CORS_ORIGINS=https://app.leerio.app

# Paths (defaults work for local dev; override for Docker)
# LEERIO_DATA=./data
# LEERIO_BOOKS=./books
